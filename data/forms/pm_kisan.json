{
    "form_id": "pm_kisan",
    "name": "PM-KISAN Samman Nidhi Application",
    "name_hi": "पीएम-किसान सम्मान निधि आवेदन",
    "description": "Apply for ₹6,000/year direct income support for farmers",
    "description_hi": "किसानों के लिए ₹6,000/वर्ष प्रत्यक्ष आय सहायता हेतु आवेदन",
    "required_documents": [
        "aadhaar",
        "land_record",
        "bank_passbook"
    ],
    "fields": [
        {
            "key": "full_name",
            "label": "Full Name",
            "label_hi": "पूरा नाम",
            "field_type": "text",
            "required": true,
            "ask_prompt_en": "Please tell me your full name:",
            "ask_prompt_hi": "कृपया अपना पूरा नाम बताएं:"
        },
        {
            "key": "aadhaar_number",
            "label": "Aadhaar Number",
            "label_hi": "आधार नंबर",
            "field_type": "aadhaar",
            "required": true,
            "ask_prompt_en": "Please share your 12-digit Aadhaar number:",
            "ask_prompt_hi": "कृपया अपना 12 अंकों का आधार नंबर बताएं:"
        },
        {
            "key": "mobile_number",
            "label": "Mobile Number",
            "label_hi": "मोबाइल नंबर",
            "field_type": "text",
            "required": true,
            "ask_prompt_en": "What is your mobile number?",
            "ask_prompt_hi": "आपका मोबाइल नंबर क्या है?"
        },
        {
            "key": "state",
            "label": "State",
            "label_hi": "राज्य",
            "field_type": "text",
            "required": true,
            "ask_prompt_en": "Which state do you live in?",
            "ask_prompt_hi": "आप किस राज्य में रहते हैं?"
        },
        {
            "key": "district",
            "label": "District",
            "label_hi": "जिला",
            "field_type": "text",
            "required": true,
            "ask_prompt_en": "Which district?",
            "ask_prompt_hi": "कौन सा जिला?"
        },
        {
            "key": "village",
            "label": "Village",
            "label_hi": "गाँव",
            "field_type": "text",
            "required": true,
            "ask_prompt_en": "Which village?",
            "ask_prompt_hi": "कौन सा गाँव?"
        },
        {
            "key": "land_acres",
            "label": "Land Area (Acres)",
            "label_hi": "भूमि क्षेत्रफल (एकड़)",
            "field_type": "number",
            "required": true,
            "ask_prompt_en": "How many acres of land do you own?",
            "ask_prompt_hi": "आपके पास कितने एकड़ ज़मीन है?"
        },
        {
            "key": "annual_income",
            "label": "Annual Income (₹)",
            "label_hi": "वार्षिक आय (₹)",
            "field_type": "number",
            "required": true,
            "ask_prompt_en": "What is your approximate yearly income (in ₹)?",
            "ask_prompt_hi": "आपकी अनुमानित वार्षिक आय कितनी है (₹ में)?"
        },
        {
            "key": "bank_account",
            "label": "Bank Account Number",
            "label_hi": "बैंक खाता संख्या",
            "field_type": "text",
            "required": true,
            "ask_prompt_en": "Please share your bank account number:",
            "ask_prompt_hi": "कृपया अपना बैंक खाता नंबर बताएं:"
        },
        {
            "key": "ifsc_code",
            "label": "IFSC Code",
            "label_hi": "IFSC कोड",
            "field_type": "text",
            "required": true,
            "ask_prompt_en": "What is your bank's IFSC code?",
            "ask_prompt_hi": "आपके बैंक का IFSC कोड क्या है?"
        }
    ]
}