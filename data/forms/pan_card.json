            "label_hi": "मोबाइल नंबर",
            "field_type": "text",
            "required": true,
            "ask_prompt_en": "What is your mobile number?",
            "ask_prompt_hi": "आपका मोबाइल नंबर क्या है?"
        },
        {
            "key": "email",
            "label": "Email Address",
            "label_hi": "ईमेल पता",
            "field_type": "text",
            "required": false,
