        {
            "key": "aadhaar_number",
            "label": "Aadhaar Number",
            "label_hi": "आधार नंबर",
            "field_type": "aadhaar",
            "required": true,
            "ask_prompt_en": "Please share your 12-digit Aadhaar number:",
            "ask_prompt_hi": "कृपया अपना 12 अंकों का आधार नंबर बताएं:"
        },
        {
            "key": "address",
            "label": "Full Address",
            "label_hi": "पूरा पता",
            "field_type": "text",
            "required": true,
            "ask_prompt_en": "What is your full address?",
            "ask_prompt_hi": "आपका पूरा पता क्या है?"
        },
        {
            "key": "pincode",
            "label": "PIN Code",
            "label_hi": "पिन कोड",
            "field_type": "text",
            "required": true,
            "ask_prompt_en": "What is your area PIN code (6 digits)?",
            "ask_prompt_hi": "आपके क्षेत्र का पिन कोड (6 अंक) क्या है?"
