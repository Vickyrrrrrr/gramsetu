# ============================================
# GramSetu v3 — Environment Configuration
# Copy to .env and fill in your values
# All services have free tiers!
# ============================================

# ── NVIDIA NIM (ALL inference — get free key at build.nvidia.com) ──
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Purpose-specific models (each tuned for its task)
NIM_MODEL_INTENT=meta/llama-3.1-8b-instruct
NIM_MODEL_CONVERSATIONAL=mistralai/mixtral-8x7b-instruct-v0.1
NIM_MODEL_EXTRACTION=meta/llama-3.1-70b-instruct
NIM_MODEL_GENERAL=meta/llama-3.3-70b-instruct
NVIDIA_VLM_MODEL=nvidia/llama-3.2-90b-vision-instruct
NVIDIA_ASR_MODEL=nvidia/parakeet-ctc-1.1b-asr

# ── Groq (OPTIONAL — emergency fallback only if NIM key missing) ────
# Free key: https://console.groq.com
# GROQ_API_KEY=your_groq_key_here
# GROQ_MODEL=llama-3.1-70b-versatile

# ── Twilio WhatsApp (free sandbox: https://www.twilio.com/try-twilio) ─
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Dashboard ────────────────────────────────────────────────
DASHBOARD_PORT=8501
API_BASE_URL=http://localhost:8000

# ── DigiLocker (leave blank = demo mock data) ────────────────
# Production: https://developers.digilocker.gov.in
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=
DIGILOCKER_REDIRECT_URI=http://localhost:8000/callback/digilocker

# ── Feature Flags ────────────────────────────────────────────
USE_V3_GRAPH=true

# ── MCP Server Ports ─────────────────────────────────────────
MCP_WHATSAPP_PORT=8100
MCP_BROWSER_PORT=8101
MCP_AUDIT_PORT=8102
MCP_DIGILOCKER_PORT=8103

# ── Vercel / public deploy (optional) ────────────────────────
# Set this if deploying Next.js to Vercel with backend on ngrok
# NEXT_PUBLIC_BACKEND_URL=https://your-ngrok-url.ngrok-free.app

# ── Dashboard ────────────────────────────────────────────────
DASHBOARD_PORT=8501
API_BASE_URL=http://localhost:8000

# ── MCP Server Ports ─────────────────────────────────────────
MCP_WHATSAPP_PORT=8100
MCP_BROWSER_PORT=8101
MCP_AUDIT_PORT=8102
MCP_DIGILOCKER_PORT=8103

# ── DigiLocker API (https://developers.digilocker.gov.in) ───
DIGILOCKER_CLIENT_ID=your_digilocker_client_id
DIGILOCKER_CLIENT_SECRET=your_digilocker_secret
DIGILOCKER_REDIRECT_URI=http://localhost:8000/callback/digilocker

# ── Feature Flags ────────────────────────────────────────────
USE_V3_GRAPH=true

# ── Database Paths ───────────────────────────────────────────
AUDIT_DB_PATH=data/audit.db
CHECKPOINT_DB_PATH=data/checkpoints.db
