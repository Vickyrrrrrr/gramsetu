# ============================================
# GramSetu v3 -- Environment Configuration
# Copy to .env and fill in your values
# ============================================

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PRIMARY LLM: Groq (intent, chat, translation, extraction)
# Free key: https://console.groq.com
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
GROQ_API_KEY=your_groq_key_here

# Groq model overrides (defaults are best-in-class free models)
GROQ_MODEL_FAST=llama-3.1-8b-instant          # intent detection (~50ms)
GROQ_MODEL_MAIN=llama-3.3-70b-versatile       # chat, translation, extraction
GROQ_MODEL_VISION=llama-3.2-11b-vision-preview

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SPECIALIZED: NVIDIA NIM (vision, ASR backup)
# Free key: https://build.nvidia.com
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# NVIDIA model overrides
NIM_MODEL_VISION=nvidia/llama-3.2-11b-vision-instruct
NIM_MODEL_GENERAL=meta/llama-3.1-8b-instruct

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Twilio WhatsApp (free sandbox)
# https://www.twilio.com/try-twilio
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Server
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
HOST=0.0.0.0
PORT=8000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DigiLocker (production credentials required for real flow)
# Production: https://developers.digilocker.gov.in
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DIGILOCKER_CLIENT_ID=your_digilocker_client_id
DIGILOCKER_CLIENT_SECRET=your_digilocker_client_secret
DIGILOCKER_REDIRECT_URI=http://localhost:8000/callback/digilocker

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Feature Flags
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
USE_V3_GRAPH=true

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# MCP Server Ports (in-process threads)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
MCP_WHATSAPP_PORT=8100
MCP_BROWSER_PORT=8101
MCP_AUDIT_PORT=8102
MCP_DIGILOCKER_PORT=8103

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Dashboard
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DASHBOARD_PORT=8501
API_BASE_URL=http://localhost:8000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Database Paths
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
AUDIT_DB_PATH=data/audit.db
CHECKPOINT_DB_PATH=data/checkpoints.db

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Optional: ngrok public URL for Twilio webhook
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# NEXT_PUBLIC_BACKEND_URL=https://your-ngrok-url.ngrok-free.app

# Security
PII_ENCRYPTION_KEY=replace_with_a_fernet_key
USE_STAGEHAND=false

# Cache / queue-ready infra
REDIS_URL=redis://localhost:6379/0
METRICS_ENABLED=true
ENVIRONMENT=development

# Observability / Workflow startup
# docker compose up --build starts backend + redis + prometheus + grafana by default
# docker compose --profile fullstack up --build also starts the Next.js web app
